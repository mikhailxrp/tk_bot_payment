# Telegram bots (two separate bot tokens, one per product)
BOT_TOKEN=
COMMON_BOT_TOKEN=
GROUP_ID=
COMMON_GROUP_ID=
ADMIN_ID=

# Robokassa (fiscalization)
ROBO_LOGIN=
ROBO_PASS1=
ROBO_PASS2=
ROBO_IS_TEST=true
ROBO_SNO=usn_income
ROBO_TAX=none

# Robokassa Result/Success/Fail URLs (must match "Технические настройки" in Robokassa cabinet)
ROBOKASSA_RESULT_URL=
ROBOKASSA_SUCCESS_URL=
ROBOKASSA_FAIL_URL=

# Database (shared by bot, admin panel and Prisma)
# Real MySQL DB on hosting: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Admin panel
ADMIN_PANEL_URL=
INTERNAL_API_TOKEN=
AUTH_SECRET=

# Bot HTTP server (Robokassa webhook)
PORT=3000
