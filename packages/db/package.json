{
  "name": "@tg-bot/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "node --env-file=../../.env ../../node_modules/prisma/build/index.js generate",
    "migrate": "node --env-file=../../.env ../../node_modules/prisma/build/index.js migrate dev",
    "migrate:deploy": "node --env-file=../../.env ../../node_modules/prisma/build/index.js migrate deploy",
    "studio": "node --env-file=../../.env ../../node_modules/prisma/build/index.js studio",
    "seed": "node --env-file=../../.env --import tsx prisma/seed.ts",
    "build": "npm run generate",
    "type-check": "tsc --noEmit"
  },
  "prisma": {
    "seed": "node --env-file=../../.env --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "tsx": "^4.19.0"
  }
}
