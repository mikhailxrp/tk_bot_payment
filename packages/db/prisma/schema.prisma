datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  NEW
  ACTIVE
  MUTED
  LEFT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ProductType {
  SUBSCRIPTION
  LIFETIME
}

model User {
  id                BigInt        @id
  username          String?
  firstName         String?
  status            UserStatus    @default(NEW)
  expiresAt         DateTime?
  reminderSentAt    DateTime?
  mutedAt           DateTime?
  lastMutedRemindAt DateTime?
  inGroup           Boolean       @default(false)
  createdAt         DateTime      @default(now())
  payments          Payment[]
  commonAccess      CommonAccess?
}

model Payment {
  id        Int           @id @default(autoincrement())
  userId    BigInt
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  product   ProductType   @default(SUBSCRIPTION)
  createdAt DateTime      @default(now())
  paidAt    DateTime?
  user      User          @relation(fields: [userId], references: [id])
}

model CommonAccess {
  userId    BigInt   @id
  paidAt    DateTime
  inGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Admin {
  telegramId   BigInt   @id
  username     String?
  email        String?  @unique
  passwordHash String?
  addedBy      BigInt?
  createdAt    DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}
